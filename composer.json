{
    "name": "itz-hurairah18/branch-inventory-system",
    "description": "Multi-Branch Inventory & Order Management System — CodeIgniter 4",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "codeigniter4/framework": "^4.5",
        "firebase/php-jwt": "^6.10"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "mikey179/vfsstream": "^1.6",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Config\\": "app/Config/"
        },
        "exclude-from-classmap": [
            "**/Database/Migrations/**"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Support\\": "tests/Support/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "codeigniter4/devkit": true
        },
        "platform": {
            "ext-intl": "1.0.0"
        },
        "audit": {
            "block-insecure": false
        }
    },
    "scripts": {
        "post-update-cmd": [
            "CodeIgniter\\ComposerScripts::postUpdate"
        ]
    }
}
